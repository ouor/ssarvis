# OpenAI API 설정
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Dashscope API 설정
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
DASHSCOPE_REALTIME_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime
DASHSCOPE_TTS_MODEL=qwen3-tts-vc-realtime-2026-01-15

# S3 설정
S3_ENABLED=true
S3_BUCKET=ssarviss3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_KEY_PREFIX=ssarvis/tts

# 데이터베이스 설정
DB_URL=jdbc:mysql://localhost:3306/ssarvisdb?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=

# FFMPEG 경로 설정
FFMPEG_PATH=ffmpeg

# 컨택스트 길이 설정
OPENAI_CHAT_HISTORY_TURNS=30

# CORS 설정
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# 인증 설정
APP_AUTH_JWT_SECRET=jwt_secret_key_jwt_secret_key_jwt_secret_key_jwt_secret_key
APP_AUTH_JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=3600

# 테스트 계정 설정
APP_BOOTSTRAP_DEFAULT_ACCOUNT_ENABLED=false
APP_BOOTSTRAP_DEFAULT_ACCOUNT_USERNAME=admin
APP_BOOTSTRAP_DEFAULT_ACCOUNT_PASSWORD=password
APP_BOOTSTRAP_DEFAULT_ACCOUNT_DISPLAY_NAME=테스트
APP_BOOTSTRAP_DEFAULT_ACCOUNT_VOICE_SAMPLE_PATHS=dev-assets/voices/furina.wav,dev-assets/voices/tartalia.wav
APP_BOOTSTRAP_DEFAULT_ACCOUNT_VOICE_ALIASES=furina,tartalia
